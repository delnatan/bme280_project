[Unit]
Description=BME280 Web Dashboard
After=network.target

[Service]
Type=simple
User=delnatan
WorkingDirectory=/home/delnatan/bme280_project
Environment=PATH=/usr/bin:/bin
ExecStart=/usr/bin/python3 -m uvicorn services.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
